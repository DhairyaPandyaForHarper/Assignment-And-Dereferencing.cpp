#include <iostream>
using namespace std;

int main() {
    char word[] = "hello";
    char* ptr = word;

    while (*ptr != '\0') {
        ptr++;
    }

    ptr--;

    cout << "Reversed string: ";

    while (ptr >= word) {
        cout << *ptr;
        ptr--;
    }

    cout << endl;

    return 0;
}
